# ══════════════════════════════════════════════════════════════
# CASATIC Directorio — Variables de entorno (PLANTILLA)
# Copiar a .env y rellenar con valores reales.
# NUNCA subas .env a Git. .env está en .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=/api

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=casatic
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=casatic_directorio

# ── Conexión que usa la API (mismas credenciales que arriba) ─
# Dentro de docker-compose el host es "db" (nombre del servicio).
CONNECTION_STRING=Host=db;Port=5432;Database=casatic_directorio;Username=casatic;Password=CHANGE_ME_strong_db_password

# ── ASP.NET Core ────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── JWT — generar con: openssl rand -base64 64 ──────────────
# Mínimo 32 caracteres. La app FALLA AL ARRANCAR si la clave es vacía
# o más corta que 32 caracteres (ver Program.cs).
JWT_KEY=CHANGE_ME_GENERATE_RANDOM_min_32_chars_use_openssl_rand_base64_64
JWT_ISSUER=CasaticDirectorio
JWT_AUDIENCE=CasaticDirectorioClients
JWT_EXPIRE_MINUTES=60

# ── CORS — orígenes permitidos separados por coma ───────────
# En producción dejá SOLO el dominio real. Sin "*".
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:5175

# ── Seed inicial del admin ──────────────────────────────────
# La primera vez que arranca la app, si no hay usuarios, crea el admin
# con estas credenciales. Cambiá la contraseña tras el primer login.
SEED_ADMIN_EMAIL=admin@casatic.org
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── pgAdmin ─────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@casatic.org
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password
